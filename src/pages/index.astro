---
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';
const name = "Abraham Fernández";
const role = "Tecnico Superior Desarollo Multiplataforma";
const location = "España";
const email = "abrahamfdezbande@gmail.com";

const links = {
  github: "https://github.com/Abrahamfdez",
  linkedin: "https://www.linkedin.com/in/abraham-fern%C3%A1ndez-bande-3661101b2/",
  cv: "/cv.pdf", // pon tu CV en /public/cv.pdf
};
---

<Layout title={`${name} · Portfolio`}>
	<header class="sticky top-0 z-50 bg-white/80 backdrop-blur border-b">
  <div class="mx-auto max-w-5xl px-6 py-3 flex justify-between items-center">

    <span class="font-bold text-slate-900">
      Abraham.me
    </span>

    <nav class="flex gap-6 text-sm">

      <a href="#about" class="hover:text-blue-600">
        Sobre mí
      </a>

      <a href="#projects" class="hover:text-blue-600">
        Proyectos
      </a>

      <a href="#contact" class="hover:text-blue-600">
        Contacto
      </a>

    </nav>

  </div>
</header>
  <main class="min-h-screen bg-gradient-to-br from-slate-50 via-white to-slate-100 text-slate-900">
    <section id="about" class="mx-auto max-w-5xl px-6 py-20 text-center">

 <h1 class="text-5xl font-bold font-mono">
  <span class="text-blue-500">function</span> 
  <span class="text-yellow-400">developer</span>() &#123;
  <br/>
  &nbsp;&nbsp;<span class="text-purple-400">return</span> 
  <span class="text-green-400">"Abraham Fernández"</span>;
  <br/>
  &#125;
</h1>

  <p class="mt-6 text-xl text-slate-600">
    Técnico Superior en Desarrollo de Aplicaciones Multiplataforma
  </p>

  <p class="mt-4 text-slate-500">
    Java · Pyhton · APIs · Flutter
  </p>

  <div class="mt-8 flex justify-center gap-4 flex-wrap">

    <a href="https://github.com/Abrahamfdez"
       class="rounded-xl bg-slate-900 px-6 py-3 text-white font-semibold hover:bg-slate-800">
       GitHub
    </a>

    <a href="https://www.linkedin.com"
       class="rounded-xl border px-6 py-3 font-semibold hover:bg-slate-100">
       LinkedIn
    </a>

    <a href="/cv.pdf"
       class="rounded-xl border px-6 py-3 font-semibold hover:bg-slate-100">
       Descargar CV
    </a>

  </div>

</section>
<section id="projects" class="mx-auto max-w-5xl px-6 py-16">
  <div class="flex items-end justify-between gap-4">
    <div>
      <h2 class="text-2xl font-bold">Proyectos</h2>
      <p class="mt-2 text-slate-600">Una selección de lo que he construido.</p>
    </div>
  </div>

  <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    <!-- Card 1 -->
    <article class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-semibold"> Ejercicios de Algoritmia</h3>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-600">Python</span>
      </div>

      <p class="mt-3 text-sm text-slate-600">
        Colección de ejercicios de Python para practicar lógica, estructuras de datos y programación orientada a objetos.
      </p>

      <div class="mt-4 flex flex-wrap gap-2">
        <span class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs text-slate-700">Python</span>
        <span class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs text-slate-700">Algoritmia</span>
        <span class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs text-slate-700">POO</span>
        <span class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs text-slate-700">JSON</span>
      </div>

      <div class="mt-6 flex gap-3">
        <a class="rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800"
           href="https://github.com/Abrahamfdez/python-ejercicios-algoritmia" target="_blank">
          Código
        </a>
        <a class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold hover:bg-slate-50"
           href="#" aria-disabled="true">
          Demo
        </a>
      </div>
    </article>

    <!-- Card 2 -->
    <article class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-semibold">API REST Java</h3>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-600">Backend</span>
      </div>

      <p class="mt-3 text-sm text-slate-600">
        API con endpoints y base de datos para practicar arquitectura y CRUD.
      </p>

      <div class="mt-4 flex flex-wrap gap-2">
        <span class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs text-slate-700">Java</span>
        <span class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs text-slate-700">REST</span>
        <span class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs text-slate-700">SQL</span>
      </div>

      <div class="mt-6 flex gap-3">
        <a class="rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800"
           href="https://github.com/Abraham-HUB-777" target="_blank">
          Código
        </a>
        <a class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold hover:bg-slate-50"
           href="#" aria-disabled="true">
          Demo
        </a>
      </div>
    </article>

    <!-- Card 3 -->
    <article class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-semibold">Portfolio</h3>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-600">Web</span>
      </div>

      <p class="mt-3 text-sm text-slate-600">
        Portfolio en Astro + Tailwind desplegado en GitHub Pages con dominio propio.
      </p>

      <div class="mt-4 flex flex-wrap gap-2">
        <span class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs text-slate-700">Astro</span>
        <span class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs text-slate-700">Tailwind</span>
        <span class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs text-slate-700">Deploy</span>
      </div>

      <div class="mt-6 flex gap-3">
        <a class="rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800"
           href="https://github.com/Abraham-HUB-777" target="_blank">
          Código
        </a>
        <a class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold hover:bg-slate-50"
           href="https://abrahamfernandez.me" target="_blank">
          Demo
        </a>
      </div>
    </article>
  </div>
</section>
<section id="skills" class="mx-auto max-w-5xl px-6 py-16">

<h2 class="text-2xl font-bold mb-8">Tecnologías</h2>

<div class="flex flex-wrap gap-6 items-center">

<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/flutter/flutter-original.svg" width="40" title="Flutter">

<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/dart/dart-original.svg" width="40" title="Dart">

<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/java/java-original.svg" width="40" title="Java">

<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg" width="40" title="Python">

<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg" width="40" title="Git">

<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg" width="40" title="HTML">

<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg" width="40" title="CSS">

<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg" width="40" title="JavaScript">

</div>

</section>
<section id="contact" class="mx-auto max-w-5xl px-6 py-16">

  <h2 class="text-2xl font-bold">Contacto</h2>

  <p class="mt-4 text-slate-600">
    Si quieres contactar conmigo para prácticas o proyectos:
  </p>

  <div class="mt-6 flex flex-wrap gap-4">

    <a 
      href="mailto:abrahamfdezbande@gmail.com"
      class="rounded-xl bg-slate-900 px-5 py-3 text-white font-semibold hover:bg-slate-800">
      Enviar Email
    </a>

    <a 
      href="https://github.com/Abraham-HUB-777"
      target="_blank"
      class="rounded-xl border px-5 py-3 font-semibold hover:bg-slate-100">
      GitHub
    </a>

    <a 
      href="https://linkedin.com"
      target="_blank"
      class="rounded-xl border px-5 py-3 font-semibold hover:bg-slate-100">
      LinkedIn
    </a>

  </div>

</section>
  </main>
</Layout>
